page {
  background: #f5f7fa;
  color: #1a1a2e;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
}

.container {
  padding: 20rpx 30rpx 120rpx;
}

/* Header */
.header {
  background: #1a1a2e;
  color: #fff;
  padding: 40rpx 30rpx 30rpx;
  margin: -20rpx -30rpx 20rpx;
}
.header-title {
  font-size: 40rpx;
  font-weight: 700;
}
.header-sub {
  font-size: 24rpx;
  opacity: 0.7;
  margin-top: 8rpx;
}

/* Form */
.form-group {
  margin-bottom: 30rpx;
}
.form-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #555;
  margin-bottom: 12rpx;
}
.form-input, .form-select {
  width: 100%;
  padding: 20rpx 24rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  font-size: 30rpx;
  background: #fafafa;
  box-sizing: border-box;
}
.form-input:focus, .form-select:focus {
  border-color: #1a1a2e;
  background: #fff;
}

.row {
  display: flex;
  gap: 20rpx;
}
.row .form-group {
  flex: 1;
}

/* Tags */
.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.tag {
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  border: 2rpx solid #e0e0e0;
  background: #fafafa;
  font-size: 26rpx;
  transition: all 0.2s;
}
.tag.selected {
  background: #1a1a2e;
  color: #fff;
  border-color: #1a1a2e;
}

/* Buttons */
.btn {
  width: 100%;
  padding: 28rpx;
  border: none;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
}
.btn-primary {
  background: #1a1a2e;
  color: #fff;
}
.btn-accent {
  background: #e94560;
  color: #fff;
}
.btn-outline {
  background: transparent;
  color: #1a1a2e;
  border: 2rpx solid #1a1a2e;
}
.btn-sm {
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  border-radius: 12rpx;
  border: none;
  font-weight: 600;
}
.btn-add { background: #00b894; color: #fff; }
.btn-del { background: #ff7675; color: #fff; }

/* City Grid */
.city-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.city-card {
  background: #fff;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
}
.city-card.selected {
  border-color: #1a1a2e;
  background: #1a1a2e;
  color: #fff;
}
.city-emoji { font-size: 48rpx; margin-bottom: 8rpx; }
.city-name { font-size: 28rpx; font-weight: 600; }

/* Custom City */
.custom-city-wrap {
  background: #fafafa;
  border-radius: 16rpx;
  border: 2rpx solid #e0e0e0;
  padding: 24rpx;
  margin-bottom: 30rpx;
}
.custom-spot-row {
  background: #fff;
  border-radius: 12rpx;
  border: 2rpx solid #eee;
  padding: 20rpx;
  margin-bottom: 16rpx;
}
.spot-list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

/* Section Title */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin: 30rpx 0 20rpx;
}

/* Day Card */
.day-card {
  background: #fff;
  border-radius: 16rpx;
  border: 2rpx solid #eee;
  margin-bottom: 24rpx;
  overflow: hidden;
}
.day-header {
  background: #1a1a2e;
  color: #fff;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  justify-content: space-between;
}
.day-header text { opacity: 0.7; font-weight: 400; font-size: 24rpx; }

.spot {
  padding: 24rpx;
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}
.spot:last-child { border-bottom: none; }
.spot.done { opacity: 0.5; }
.spot.done .spot-title { text-decoration: line-through; }
.spot-check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 4rpx solid #ccc;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 4rpx;
}
.spot.done .spot-check {
  background: #00b894;
  border-color: #00b894;
}
.spot-check::after {
  content: "✓";
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  opacity: 0;
}
.spot.done .spot-check::after { opacity: 1; }
.spot-info { flex: 1; }
.spot-time {
  font-size: 22rpx;
  color: #e94560;
  font-weight: 600;
  margin-bottom: 4rpx;
}
.spot-title { font-size: 30rpx; font-weight: 600; }
.spot-desc {
  font-size: 24rpx;
  color: #888;
  margin-top: 4rpx;
  line-height: 1.4;
}
.spot-type {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
  color: #666;
  margin-top: 8rpx;
  display: inline-block;
}

/* Status Panel */
.status-panel {
  background: #fff;
  border-radius: 16rpx;
  border: 2rpx solid #eee;
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.status-title {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 16rpx;
}
.current-spot {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.current-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: #e94560;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}
.current-text { flex: 1; }
.current-title { font-size: 32rpx; font-weight: 700; }
.current-sub { font-size: 24rpx; color: #888; margin-top: 4rpx; }

/* Next Card */
.next-card {
  background: #1a1a2e;
  color: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}
.next-label {
  font-size: 20rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  opacity: 0.6;
  margin-bottom: 8rpx;
}
.next-title { font-size: 40rpx; font-weight: 700; margin-bottom: 8rpx; }
.next-desc { font-size: 26rpx; opacity: 0.8; line-height: 1.5; }
.next-meta {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
  font-size: 24rpx;
  opacity: 0.7;
}
.next-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}
.next-actions .btn { flex: 1; padding: 20rpx; font-size: 28rpx; }

/* Progress */
.progress-wrap {
  background: #fff;
  border-radius: 16rpx;
  border: 2rpx solid #eee;
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.progress-bar {
  height: 16rpx;
  background: #eee;
  border-radius: 8rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: #00b894;
  border-radius: 8rpx;
  transition: width 0.4s ease;
}
.progress-text {
  font-size: 24rpx;
  color: #888;
  margin-top: 12rpx;
}

/* Stats */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.stat-box {
  background: #fff;
  border-radius: 16rpx;
  border: 2rpx solid #eee;
  padding: 24rpx 16rpx;
  text-align: center;
}
.stat-num { font-size: 48rpx; font-weight: 700; color: #1a1a2e; }
.stat-label { font-size: 22rpx; color: #888; margin-top: 4rpx; }

/* Weather */
.weather-bar {
  background: #fff;
  border-radius: 16rpx;
  border: 2rpx solid #eee;
  padding: 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.weather-icon { font-size: 56rpx; }
.weather-info { flex: 1; }
.weather-city { font-size: 28rpx; font-weight: 700; }
.weather-desc { font-size: 24rpx; color: #666; margin-top: 4rpx; }
.weather-alert {
  background: #fff3cd;
  border: 2rpx solid #ffc107;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 24rpx;
  font-size: 26rpx;
  color: #856404;
}

/* Tabs */
.tabs {
  display: flex;
  border-bottom: 2rpx solid #eee;
  margin: 0 -30rpx 24rpx;
  padding: 0 30rpx;
  gap: 32rpx;
}
.tab {
  padding: 16rpx 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #888;
  border-bottom: 5rpx solid transparent;
}
.tab.active {
  color: #1a1a2e;
  border-bottom-color: #e94560;
}

/* Modal */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 150;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}
.modal-content {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  width: 100%;
}
.modal-title { font-size: 36rpx; font-weight: 700; margin-bottom: 16rpx; }
.modal-body { font-size: 28rpx; color: #666; margin-bottom: 32rpx; }
.modal-actions { display: flex; gap: 20rpx; }
.modal-actions .btn { flex: 1; }

/* Empty */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #888;
  font-size: 28rpx;
}
